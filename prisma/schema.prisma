generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id       Int          @id @default(autoincrement())
  nome     String
  email    String       @unique
  senha    String
  cargo    String       @default("OPERACIONAL") // COMERCIAL | OPERACIONAL | FINANCEIRO
  criadoEm DateTime    @default(now())
  servicos Servico[]
}

model Veiculo {
  id          Int       @id @default(autoincrement())
  nome        String
  apelido     String?   // Internal nickname e.g. "Munck 01", "Guindaste 40"
  tipo        String    // MUNCK | GUINDASTE | EMPILHADEIRA
  placa       String    @unique
  capacidade  Float?
  status      String    @default("DISPONIVEL") // DISPONIVEL | EM_USO | MANUTENCAO
  observacoes String?
  servicos    Servico[]
}

model Funcionario {
  id          Int       @id @default(autoincrement())
  nome        String
  funcao      String    // OPERADOR | MOTORISTA | AUXILIAR
  telefone    String?
  status      String    @default("FOLGA") // TRABALHANDO | FOLGA
  observacoes String?
  servicos    Servico[]
}

model Servico {
  id                    Int          @id @default(autoincrement())
  // Client info
  cliente               String
  localidade            String
  descricao             String?
  // Requester / contact
  solicitante           String?      // Name of the person who requested
  contatoPagamento      String?      // Phone of person responsible for payment
  // Scheduling
  dataInicio            DateTime
  dataFim               DateTime?
  status                String       @default("AGENDADO") // AGENDADO | EM_ANDAMENTO | CONCLUIDO | CANCELADO
  // Two-step scheduling: first by type, then assign specific vehicle
  tipoVeiculoSolicitado String?      // MUNCK | GUINDASTE | EMPILHADEIRA (when no specific vehicle yet)
  qtdVeiculos           Int          @default(1) // How many vehicles needed of this type
  veiculoId             Int?         // Nullable: assigned later by operational manager
  // Personnel
  funcionarioId         Int?         // Also optional initially
  // Service type & pricing (Finance)
  tipoServico           String?      // POR_HORA | POR_HORA_KM
  valores               String?      // Pricing details (free text)
  formaPagamento        String?      // Payment method
  // Meta
  criadoPorId           Int
  criadoEm              DateTime     @default(now())
  // Relations
  veiculo               Veiculo?     @relation(fields: [veiculoId], references: [id])
  funcionario           Funcionario? @relation(fields: [funcionarioId], references: [id])
  criadoPor             Usuario      @relation(fields: [criadoPorId], references: [id])
}
