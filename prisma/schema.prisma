generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id       Int          @id @default(autoincrement())
  nome     String
  email    String       @unique
  senha    String
  cargo    String       @default("OPERACIONAL") // COMERCIAL | OPERACIONAL | FINANCEIRO
  criadoEm DateTime    @default(now())
  servicos Servico[]
}

model Veiculo {
  id               Int              @id @default(autoincrement())
  nome             String
  apelido          String?          // Internal nickname e.g. "Munck 01", "Guindaste 40"
  tipo             String           // MUNCK | GUINDASTE | EMPILHADEIRA
  placa            String           @unique
  capacidade       Float?
  status           String           @default("DISPONIVEL") // DISPONIVEL | EM_USO | MANUTENCAO
  observacoes      String?
  servicos         Servico[]
  servicosAlocados ServicoVeiculo[]
}

model Funcionario {
  id          Int       @id @default(autoincrement())
  nome        String
  funcao      String    // OPERADOR | MOTORISTA | AUXILIAR
  telefone    String?
  status      String    @default("FOLGA") // TRABALHANDO | FOLGA
  observacoes String?
  servicos    Servico[]
}

model Servico {
  id                    Int              @id @default(autoincrement())
  numeroOS              Int?             @unique // Sequential display number, never reused
  // Client info
  cliente               String
  localidade            String
  descricao             String?
  // Requester / contact
  solicitante           String?
  contatoPagamento      String?
  // Scheduling
  dataInicio            DateTime
  dataFim               DateTime?
  status                String           @default("AGENDADO") // AGENDADO | EM_ANDAMENTO | CONCLUIDO | CANCELADO
  // Two-step scheduling: first by type, then assign specific vehicle
  tipoVeiculoSolicitado String?
  qtdVeiculos           Int              @default(1)
  veiculoId             Int?             // Legacy single-vehicle FK (kept for backward compat)
  // Personnel
  funcionarioId         Int?
  // Service type & pricing (Finance)
  tipoServico           String?
  valores               String?
  formaPagamento        String?
  // Public sharing token
  tokenPublico          String?          @unique
  tokenExpiraEm         DateTime?
  // Meta
  criadoPorId           Int
  criadoEm              DateTime         @default(now())
  // Relations
  veiculo               Veiculo?         @relation(fields: [veiculoId], references: [id])
  veiculosAlocados      ServicoVeiculo[]
  funcionario           Funcionario?     @relation(fields: [funcionarioId], references: [id])
  criadoPor             Usuario          @relation(fields: [criadoPorId], references: [id])
}

model ServicoVeiculo {
  servicoId Int
  veiculoId Int
  servico   Servico @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  veiculo   Veiculo @relation(fields: [veiculoId], references: [id])

  @@id([servicoId, veiculoId])
}
